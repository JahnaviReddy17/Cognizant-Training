1. User Upcoming Events

```sql
SELECT e.*
FROM events e
JOIN registrations r ON e.event_id = r.event_id
WHERE r.user_id = ?
  AND e.date >= CURDATE()
ORDER BY e.date;
```

2. Top Rated Events

```sql
SELECT event_id, AVG(rating) AS avg_rating
FROM feedback
GROUP BY event_id
HAVING COUNT(*) >= 10
ORDER BY avg_rating DESC;
```

3. Inactive Users

```sql
SELECT u.user_id
FROM users u
LEFT JOIN registrations r
ON u.user_id = r.user_id
AND r.created_at >= DATE_SUB(CURDATE(), INTERVAL 90 DAY)
WHERE r.user_id IS NULL;
```

4. Peak Session Hours

```sql
SELECT event_id, COUNT(*) AS session_count
FROM sessions
WHERE HOUR(start_time) BETWEEN 10 AND 11
GROUP BY event_id;
```

5. Most Active Cities

```sql
SELECT u.city, COUNT(DISTINCT r.user_id) AS total_users
FROM users u
JOIN registrations r ON u.user_id = r.user_id
GROUP BY u.city
ORDER BY total_users DESC
LIMIT 5;
```

6. Event Resource Summary

```sql
SELECT event_id, COUNT(*) AS total_resources
FROM resources
GROUP BY event_id;
```

7. Low Feedback Alerts

```sql
SELECT u.user_id, f.comment, e.event_name
FROM feedback f
JOIN users u ON u.user_id = f.user_id
JOIN events e ON e.event_id = f.event_id
WHERE f.rating < 3;
```

8. Sessions per Upcoming Event

```sql
SELECT e.event_id, COUNT(s.session_id)
FROM events e
LEFT JOIN sessions s ON e.event_id = s.event_id
WHERE e.date >= CURDATE()
GROUP BY e.event_id;
```

9. Organizer Event Summary

```sql
SELECT organizer_id,
       COUNT(*) AS total_events,
       status
FROM events
GROUP BY organizer_id, status;
```

10. Feedback Gap

```sql
SELECT e.event_id
FROM events e
JOIN registrations r ON e.event_id = r.event_id
LEFT JOIN feedback f ON e.event_id = f.event_id
WHERE f.event_id IS NULL;
```

11. Daily New User Count

```sql
SELECT DATE(created_at), COUNT(*)
FROM users
WHERE created_at >= DATE_SUB(CURDATE(), INTERVAL 7 DAY)
GROUP BY DATE(created_at);
```

12. Event with Maximum Sessions

```sql
SELECT event_id
FROM sessions
GROUP BY event_id
ORDER BY COUNT(*) DESC
LIMIT 1;
```

13. Average Rating per City

```sql
SELECT e.city, AVG(f.rating)
FROM events e
JOIN feedback f ON e.event_id = f.event_id
GROUP BY e.city;
```

14. Most Registered Events

```sql
SELECT event_id, COUNT(*) AS total
FROM registrations
GROUP BY event_id
ORDER BY total DESC
LIMIT 3;
```

15. Event Session Time Conflict

```sql
SELECT s1.*
FROM sessions s1
JOIN sessions s2
ON s1.event_id = s2.event_id
AND s1.session_id <> s2.session_id
WHERE s1.start_time < s2.end_time
  AND s1.end_time > s2.start_time;
```

16. Unregistered Active Users

```sql
SELECT u.user_id
FROM users u
LEFT JOIN registrations r
ON u.user_id = r.user_id
AND r.created_at >= DATE_SUB(CURDATE(), INTERVAL 30 DAY)
WHERE r.user_id IS NULL;
```

17. Multi-Session Speakers

```sql
SELECT speaker_id
FROM sessions
GROUP BY speaker_id
HAVING COUNT(*) > 1;
```

18. Resource Availability Check

```sql
SELECT e.event_id
FROM events e
LEFT JOIN resources r ON e.event_id = r.event_id
WHERE r.event_id IS NULL;
```

19. Completed Events with Feedback Summary

```sql
SELECT e.event_id,
       COUNT(r.user_id),
       AVG(f.rating)
FROM events e
LEFT JOIN registrations r ON e.event_id = r.event_id
LEFT JOIN feedback f ON e.event_id = f.event_id
WHERE e.status = 'completed'
GROUP BY e.event_id;
```

20. User Engagement Index

```sql
SELECT u.user_id,
       COUNT(DISTINCT r.event_id),
       COUNT(f.feedback_id)
FROM users u
LEFT JOIN registrations r ON u.user_id = r.user_id
LEFT JOIN feedback f ON u.user_id = f.user_id
GROUP BY u.user_id;
```

21. Top Feedback Providers

```sql
SELECT user_id, COUNT(*) AS total_feedback
FROM feedback
GROUP BY user_id
ORDER BY total_feedback DESC
LIMIT 5;
```

22. Duplicate Registrations Check

```sql
SELECT user_id, event_id
FROM registrations
GROUP BY user_id, event_id
HAVING COUNT(*) > 1;
```

23. Registration Trends

```sql
SELECT DATE_FORMAT(created_at, '%Y-%m') AS month,
       COUNT(*)
FROM registrations
GROUP BY month;
```

24. Average Session Duration per Event

```sql
SELECT event_id,
       AVG(TIMESTAMPDIFF(MINUTE, start_time, end_time))
FROM sessions
GROUP BY event_id;
```

25. Events Without Sessions

```sql
SELECT e.event_id
FROM events e
LEFT JOIN sessions s ON e.event_id = s.event_id
WHERE s.session_id IS NULL;
```
